# ─── Claude OAuth ────────────────────────────────────────────────────────────
# Get this from ~/.claude.json after logging in locally with `claude`
# DO NOT set ANTHROPIC_API_KEY — it will override OAuth and bill your API account
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here

# ─── Discord ─────────────────────────────────────────────────────────────────
# Bot token from discord.com/developers → your app → Bot → Token
DISCORD_BOT_TOKEN=your_bot_token_here
# Application ID from discord.com/developers → your app → General Information
DISCORD_APP_ID=your_application_id_here

# ─── Cron timezone ───────────────────────────────────────────────────────────
# Timezone for cron job scheduling (IANA format)
CRON_TZ=America/Denver

# ─── Add your own service credentials below ──────────────────────────────────
# Examples:
# POSTGRES_URL=postgresql://user:pass@host:5432/mydb
# OPENAI_API_KEY=sk-...
# SOME_API_KEY=...
